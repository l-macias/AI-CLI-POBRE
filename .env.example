# Zero Runtime environment example
# Copy this file to .env only for local development.
# Never commit .env.

NODE_ENV=development

# OpenRouter real-provider configuration
# Real provider calls are disabled unless the CLI/test explicitly opts in.
#
# Required only when running real-provider flows:
# - npm run real-provider:test
# - npm run repair:openrouter-smoke:test
# - npm run agent:real-provider-smoke:test
#
# Do not put real API keys in logs, docs, reports, tests, or committed files.

ZERO_OPENROUTER_ENABLED=0
ZERO_RUN_REAL_PROVIDER_TEST=0

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=

# Optional OpenRouter metadata
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Zero Runtime

# Runtime/provider limits
ZERO_OPENROUTER_TIMEOUT_MS=30000
ZERO_OPENROUTER_MAX_TOKENS=1200